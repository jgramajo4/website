---
type ProjectStatus = "active" | "building" | "archived";

type ProjectData = {
	name: string;
	status: ProjectStatus;
	description: string;
	url: string;
	tags?: string[];
};

const { project } = Astro.props as { project: ProjectData };

const statusLabelMap: Record<ProjectStatus, string> = {
	active: "Active",
	building: "Building",
	archived: "Archived",
};

const statusToneMap: Record<ProjectStatus, string> = {
	active: "project-card__status--active",
	building: "project-card__status--building",
	archived: "project-card__status--archived",
};

const statusLabel = statusLabelMap[project.status];
const statusTone = statusToneMap[project.status];
const tags = Array.isArray(project.tags) ? project.tags.filter(Boolean) : [];
---

<article class="project-card">
	<header class="project-card__header">
		<div class="project-card__title-row">
			<h3 class="project-card__title">
				{project.name}
			</h3>

			<span class={`project-card__status ${statusTone}`}>
				{statusLabel}
			</span>
		</div>

		<p class="project-card__description">
			{project.description}
		</p>
	</header>

	{tags.length > 0 && (
		<ul class="project-card__tags" aria-label="Tags">
			{tags.map((tag) => (
				<li class="project-card__tag">{tag}</li>
			))}
		</ul>
	)}

	<footer class="project-card__footer">
		<a class="project-card__link" href={project.url} rel="noopener noreferrer">
			Visit project ↗
		</a>
	</footer>
</article>

<style>
	.project-card {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		padding: clamp(1.75rem, 4vw, 2.25rem);
		border: 1px solid var(--color-border);
		border-radius: calc(var(--radius-card) / 1.1);
		background: rgba(32, 32, 32, 0.85);
		box-shadow: 0 24px 42px rgba(0, 0, 0, 0.35);
		transition: border-color var(--transition-base), transform var(--transition-base);
	}

	.project-card:hover,
	.project-card:focus-within {
		border-color: var(--color-accent);
		transform: translateY(-2px);
	}

	.project-card__header {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.project-card__title-row {
		display: flex;
		align-items: baseline;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.project-card__title {
		margin: 0;
		font-size: clamp(1.35rem, 3vw, 1.7rem);
		letter-spacing: -0.02em;
	}

	.project-card__status {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.25rem 0.65rem;
		border-radius: 999px;
		font-size: 0.75rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		border: 1px solid transparent;
	}

	.project-card__status::before {
		content: "";
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 999px;
	}

	.project-card__status--active {
		color: #22c55e;
		background: rgba(34, 197, 94, 0.12);
		border-color: rgba(34, 197, 94, 0.35);
	}

	.project-card__status--active::before {
		background: #22c55e;
	}

	.project-card__status--building {
		color: #facc15;
		background: rgba(250, 204, 21, 0.12);
		border-color: rgba(250, 204, 21, 0.35);
	}

	.project-card__status--building::before {
		background: #facc15;
	}

	.project-card__status--archived {
		color: #9ca3af;
		background: rgba(156, 163, 175, 0.12);
		border-color: rgba(156, 163, 175, 0.35);
	}

	.project-card__status--archived::before {
		background: #9ca3af;
	}

	.project-card__description {
		margin: 0;
		color: var(--color-text);
		font-size: 0.98rem;
		line-height: 1.65;
	}

	.project-card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.project-card__tag {
		padding: 0.3rem 0.6rem;
		border-radius: 6px;
		background: rgba(74, 222, 128, 0.12);
		border: 1px solid rgba(74, 222, 128, 0.2);
		font-size: 0.75rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.project-card__footer {
		display: flex;
		justify-content: flex-start;
	}

	.project-card__link {
		font-size: 0.82rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-accent);
		border-bottom: 1px solid transparent;
		padding-bottom: 0.2rem;
		transition: border-color var(--transition-base);
	}

	.project-card__link:hover,
	.project-card__link:focus-visible {
		border-color: var(--color-accent);
	}

	@media (max-width: 640px) {
		.project-card {
			padding: 1.5rem;
		}
	}
</style>
