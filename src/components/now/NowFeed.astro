---
const FEED_ID = "now-feed-island";
const BLUESKY_REPO = "gramajo.xyz";
const BLUESKY_COLLECTION = "app.bsky.feed.post";
const BLUESKY_LIMIT = "20";
---

<div
	id={FEED_ID}
	class="now-feed"
	data-state="loading"
	data-repo={BLUESKY_REPO}
	data-collection={BLUESKY_COLLECTION}
	data-limit={BLUESKY_LIMIT}
>
	<p class="now-feed__status">Loading the latest Now updates…</p>
</div>

<style>
	.now-feed {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}
	.now-feed[data-state="error"] .now-feed__status,
	.now-feed[data-state="empty"] .now-feed__status {
		color: var(--color-muted);
	}
	.now-feed__status {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.92rem;
	}
	.now-feed__list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}
	.now-feed__item {
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--color-border);
	}
	.now-feed__item:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}
	.now-feed__post {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.now-feed__text {
		margin: 0;
		white-space: pre-wrap;
		line-height: 1.65;
		font-size: 0.95rem;
		color: var(--color-text);
	}
	.now-feed__meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		font-size: 0.78rem;
		color: var(--color-muted);
		letter-spacing: 0.04em;
	}
	.now-feed__permalink {
		color: var(--color-accent);
		font-size: 0.75rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}
	@media (max-width: 540px) {
		.now-feed__meta {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>

<script>
	(function () {
		const container = document.getElementById("now-feed-island");
		if (!container) return;

		const repo = container.dataset.repo ?? "gramajo.xyz";
		const collection = container.dataset.collection ?? "app.bsky.feed.post";
		const limit = container.dataset.limit ?? "20";

		const endpoint = new URL("https://public.api.bsky.app/xrpc/com.atproto.repo.listRecords");
		endpoint.searchParams.set("repo", repo);
		endpoint.searchParams.set("collection", collection);
		endpoint.searchParams.set("limit", limit);

		const dateFormatter = new Intl.DateTimeFormat("en-US", {
			dateStyle: "medium",
			timeStyle: "short",
		});

		function escapeHtml(str: string): string {
			return str
				.replace(/&/g, "&amp;")
				.replace(/</g, "&lt;")
				.replace(/>/g, "&gt;");
		}

		function renderStatus(message: string, state = "info") {
			container.dataset.state = state;
			container.innerHTML = `<p class="now-feed__status">${escapeHtml(message)}</p>`;
		}

		function renderPosts(posts: Array<{ rkey: string; text: string; createdAtIso: string; createdAtLabel: string }>) {
			if (!posts.length) {
				renderStatus("No Bluesky updates yet. Check back soon.", "empty");
				return;
			}

			const items = posts
				.map((post) => {
					const text = escapeHtml(post.text);
					const time = escapeHtml(post.createdAtIso);
					const label = escapeHtml(post.createdAtLabel);
					const rkey = encodeURIComponent(post.rkey);
					return `<li class="now-feed__item">
						<article class="now-feed__post">
							<p class="now-feed__text">${text}</p>
							<footer class="now-feed__meta">
								<time datetime="${time}">${label}</time>
								<a class="now-feed__permalink" href="/now?rkey=${rkey}">open ↗</a>
							</footer>
						</article>
					</li>`;
				})
				.join("");

			container.dataset.state = "success";
			container.innerHTML = `<ul class="now-feed__list">${items}</ul>`;
		}

		function normalizeRecords(records: unknown[]): Array<{ rkey: string; text: string; createdAtIso: string; createdAtLabel: string }> {
			return records
				.map((record: unknown) => {
					const r = record as { rkey?: string; value?: { text?: unknown; createdAt?: unknown } };
					const text = typeof r.value?.text === "string" ? r.value.text.trim() : "";
					const createdAt = typeof r.value?.createdAt === "string" ? r.value.createdAt : null;
					if (!text || !createdAt || !r.rkey) return null;

					const date = new Date(createdAt);
					const createdAtLabel = Number.isNaN(date.getTime())
						? createdAt
						: dateFormatter.format(date);

					return { rkey: r.rkey, text, createdAtIso: createdAt, createdAtLabel };
				})
				.filter((x): x is NonNullable<typeof x> => x !== null)
				.sort((a, b) => new Date(b.createdAtIso).getTime() - new Date(a.createdAtIso).getTime());
		}

		async function loadFeed() {
			renderStatus("Loading the latest Now updates…", "loading");
			try {
				const response = await fetch(endpoint.toString(), {
					headers: { Accept: "application/json" },
				});
				if (!response.ok) throw new Error(`API responded with ${response.status}`);
				const payload = await response.json() as { records?: unknown[] };
				const posts = normalizeRecords(payload.records ?? []);
				renderPosts(posts);
			} catch (error) {
				console.error("[NowFeed]", error);
				renderStatus("No updates yet. Check back soon.", "empty");
			}
		}

		loadFeed();
	})();
</script>
