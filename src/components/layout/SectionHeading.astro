---
type Props = {
	title: string;
	subtitle?: string;
	eyebrow?: string;
	anchorId?: string;
	align?: "start" | "center";
};

const {
	title,
	subtitle,
	eyebrow,
	anchorId,
	align = "start",
} = Astro.props as Props;

const normalizedId =
	anchorId ??
	title
		.toLowerCase()
		.trim()
		.replace(/[^a-z0-9\s-]/g, "")
		.replace(/\s+/g, "-");
---

<header
	class={`section-heading section-heading--${align}`}
	aria-labelledby={normalizedId}
>
	{eyebrow && <span class="section-heading__eyebrow">{eyebrow}</span>}
	<h2 id={normalizedId} class="section-heading__title">
		{title}
	</h2>
	{subtitle && <p class="section-heading__subtitle">{subtitle}</p>}
</header>

<style>
	.section-heading {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		margin-bottom: 2rem;
		text-align: left;
	}

	.section-heading--center {
		text-align: center;
		align-items: center;
	}

	.section-heading__eyebrow {
		color: var(--color-muted);
		font-size: 0.75rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	.section-heading__title {
		font-size: clamp(1.5rem, 2.4vw, 2.15rem);
		margin: 0;
	}

	.section-heading__subtitle {
		margin: 0;
		color: var(--color-muted);
		max-width: 55ch;
	}
</style>
