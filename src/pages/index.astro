---
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { BearBlogPost } from "@/utils/rss";
import { BearBlogFeedError, fetchBearBlogFeed } from "@/utils/rss";
import NowFeed from "@/components/now/NowFeed.astro";

const POST_LIMIT = 6;
const BLOG_ARCHIVE_URL = "https://0xgramajo.xyz/blog/";

let posts: BearBlogPost[] = [];
let errorMessage: string | null = null;
let fallbackUrl = BLOG_ARCHIVE_URL;

try {
	posts = await fetchBearBlogFeed(POST_LIMIT);
} catch (error) {
	console.error("[home] Failed to load Bear Blog feed.", error);
	if (error instanceof BearBlogFeedError) {
		errorMessage = "Unable to load the Bear Blog feed right now.";
		fallbackUrl = error.fallbackUrl;
	} else if (error instanceof Error) {
		errorMessage = error.message;
	} else {
		errorMessage = "Unable to load the latest posts right now.";
	}
}

const formatDate = (isoDate: string) =>
	new Date(isoDate).toLocaleDateString("en-US", {
		year: "numeric",
		month: "short",
		day: "numeric",
	});
---

<BaseLayout description="Ops nerd building an open web from the command line.">
	<header class="hero">
		<h1 class="hero__title">gramajo</h1>
		<p class="hero__bio">
			My name is Juan or better known as Gramajo. I'm an Ops nerd with a passion for Legal Tech and anything that
			advances an open web. I'm currently working at Asana and I work on other projects in my spare time. See what
			I'm up to now!
		</p>
	</header>

	<section class="contact">
		<h2 class="contact__title">Contact</h2>
		<ul class="contact__links">
			<li><a href="mailto:onchainaliens@gmail.com">Email</a></li>
			<li><span>Signal: gramajo.04</span></li>
			<li><a href="https://t.me/jgramajo4" rel="noopener noreferrer">Telegram</a></li>
			<li><a href="https://bsky.app/profile/gramajo.xyz" rel="noopener noreferrer">Bluesky (@gramajo.xyz)</a></li>
		</ul>
	</section>

	<section class="posts">
		<header class="section-header">
			<h2 class="section-header__title">Posts</h2>
			<a class="section-header__cta" href={BLOG_ARCHIVE_URL} rel="noopener noreferrer">View all ↗</a>
		</header>

		{errorMessage ? (
			<p class="status status--error">
				{errorMessage} <a href={fallbackUrl} rel="noopener noreferrer">Visit Bear Blog ↗</a>
			</p>
		) : posts.length === 0 ? (
			<p class="status">
				No posts available right now. Visit{" "}
				<a href={BLOG_ARCHIVE_URL} rel="noopener noreferrer">Bear Blog ↗</a> to read the archive.
			</p>
		) : (
			<ul class="posts__list">
				{posts.map((post) => (
					<li class="posts__item">
						<time class="posts__date" datetime={post.publishedIso}>{formatDate(post.publishedIso)}</time>
						<a class="posts__link" href={post.url} rel="noopener noreferrer">
							{post.title}
						</a>
					</li>
				))}
			</ul>
		)}
	</section>

	<section class="now">
		<header class="section-header">
			<h2 class="section-header__title">Now</h2>
			<p class="section-header__subtitle">Live from Bluesky · refreshed often.</p>
		</header>

		<NowFeed />
	</section>
</BaseLayout>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		margin-bottom: 3rem;
	}

	.hero__title {
		margin: 0;
		font-size: clamp(3rem, 8vw, 4.5rem);
		letter-spacing: -0.04em;
		line-height: 0.95;
		text-transform: lowercase;
	}

	.hero__bio {
		margin: 0;
		max-width: 62ch;
		color: var(--color-muted);
		font-size: 1rem;
		line-height: 1.8;
	}

	.contact {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-bottom: 3.5rem;
	}

	.contact__title {
		margin: 0;
		font-size: 1rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-accent);
	}

	.contact__links {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 1.25rem;
		margin: 0;
		padding: 0;
		font-size: 0.95rem;
	}

	.contact__links a,
	.contact__links span {
		color: var(--color-text);
	}

	.contact__links a:hover,
	.contact__links a:focus-visible {
		color: var(--color-accent);
		text-decoration: none;
	}

	.section-header {
		display: flex;
		align-items: baseline;
		gap: 0.75rem;
		margin-bottom: 1.5rem;
	}

	.section-header__title {
		margin: 0;
		font-size: 1.15rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.section-header__cta {
		margin-left: auto;
		font-size: 0.82rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-accent);
	}

	.section-header__subtitle {
		margin: 0;
		font-size: 0.82rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.posts {
		display: flex;
		flex-direction: column;
		margin-bottom: 3.5rem;
	}

	.posts__list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 1.25rem;
	}

	.posts__item {
		display: grid;
		grid-template-columns: minmax(120px, 160px) 1fr;
		gap: 1.5rem;
		align-items: center;
		padding-bottom: 1.25rem;
		border-bottom: 1px solid var(--color-border);
	}

	.posts__item:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.posts__date {
		font-size: 0.85rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.posts__link {
		font-size: 1rem;
		color: var(--color-text);
		transition: color var(--transition-base);
	}

	.posts__link:hover,
	.posts__link:focus-visible {
		color: var(--color-accent);
	}

	.status {
		margin: 0;
		font-size: 0.95rem;
		color: var(--color-muted);
	}

	.status--error {
		color: #f87171;
	}

	.now {
		display: flex;
		flex-direction: column;
		gap: 1.75rem;
	}

	@media (max-width: 720px) {
		.posts__item {
			grid-template-columns: 1fr;
			gap: 0.75rem;
			align-items: flex-start;
		}

		.section-header {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.5rem;
		}

		.section-header__cta {
			margin-left: 0;
		}
	}
</style>
