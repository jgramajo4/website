---
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { BearBlogPost } from "@/utils/rss";
import { BearBlogFeedError, fetchBearBlogFeed } from "@/utils/rss";
import NowFeed from "@/components/now/NowFeed.astro";

const POST_LIMIT = 6;
const BLOG_ARCHIVE_URL = "https://0xgramajo.xyz/blog/";

let posts: BearBlogPost[] = [];
let errorMessage: string | null = null;
let fallbackUrl = BLOG_ARCHIVE_URL;

try {
    posts = await fetchBearBlogFeed(POST_LIMIT);
} catch (error) {
    console.error("[home] Failed to load Bear Blog feed.", error);
    if (error instanceof BearBlogFeedError) {
        errorMessage = "Unable to load the Bear Blog feed right now.";
        fallbackUrl = error.fallbackUrl;
    } else if (error instanceof Error) {
        errorMessage = error.message;
    } else {
        errorMessage = "Unable to load the latest posts right now.";
    }
}

const formatDate = (isoDate: string) =>
    new Date(isoDate).toLocaleDateString("en-US", {
        year: "numeric",
        month: "short",
        day: "numeric",
    });

const socials = [
    {
        label: "Email",
        href: "mailto:onchainaliens@gmail.com",
        // Envelope
        icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
    },
    {
        label: "Bluesky",
        href: "https://bsky.app/profile/gramajo.xyz",
        // Bluesky butterfly
        icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 10.8c-1.087-2.114-4.046-6.053-6.798-7.995C2.566.944 1.561 1.266.902 1.565.139 1.908 0 3.08 0 3.768c0 .69.378 5.65.624 6.479.815 2.736 3.713 3.66 6.383 3.364.136-.02.275-.039.415-.056-.138.022-.276.04-.415.056-3.912.58-7.387 2.005-2.83 7.078 5.013 5.19 6.87-1.113 7.823-4.308.953 3.195 2.05 9.271 7.733 4.308 4.267-4.308 1.172-6.498-2.74-7.078a8.741 8.741 0 0 1-.415-.056c.14.017.279.036.415.056 2.67.297 5.568-.628 6.383-3.364.246-.828.624-5.79.624-6.478 0-.69-.139-1.861-.902-2.204-.659-.299-1.664-.62-4.3 1.24C16.046 4.748 13.087 8.687 12 10.8Z"/></svg>`,
    },
    {
        label: "Telegram",
        href: "https://t.me/jgramajo4",
        // Telegram paper plane
        icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>`,
    },
    {
        label: "GitHub",
        href: "https://github.com/jgramajo4",
        // GitHub mark
        icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>`,
    },
    {
        label: "ENS",
        href: "https://app.ens.domains/gramajo.eth",
        title: "gramajo.eth",
        // ETH diamond shape
        icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 2 7 10-7 3-7-3z"/><path d="m12 22-7-7 7-3 7 3z"/></svg>`,
    },
];
---

<BaseLayout description="Ops nerd building an open web from the command line.">
    <header class="hero">
        <h1 class="hero__title">gramajo</h1>
        <p class="hero__bio">
            My name is Juan or better known as Gramajo. I'm an Ops nerd with a
            passion for Legal Tech and anything that advances an open web. I'm
            currently working at Asana and I work on other projects in my spare
            time. See what I'm up to now!
        </p>
    </header>

    <div class="social-row">
        <span class="social-row__label">Find me on</span>
        <ul class="social-icons">
            {
                socials.map((s) => (
                    <li>
                        <a
                            class="social-icon"
                            href={s.href}
                            title={s.title ?? s.label}
                            aria-label={s.title ?? s.label}
                            rel={
                                s.href.startsWith("http")
                                    ? "noopener noreferrer"
                                    : undefined
                            }
                        >
                            <Fragment set:html={s.icon} />
                        </a>
                    </li>
                ))
            }
        </ul>
    </div>

    <section class="posts">
        <header class="section-header">
            <h2 class="section-header__title">Posts</h2>
            <a
                class="section-header__cta"
                href={BLOG_ARCHIVE_URL}
                rel="noopener noreferrer">View all ↗</a
            >
        </header>

        {
            errorMessage ? (
                <p class="status status--error">
                    {errorMessage}{" "}
                    <a href={fallbackUrl} rel="noopener noreferrer">
                        Visit Bear Blog ↗
                    </a>
                </p>
            ) : posts.length === 0 ? (
                <p class="status">
                    No posts available right now. Visit{" "}
                    <a href={BLOG_ARCHIVE_URL} rel="noopener noreferrer">
                        Bear Blog ↗
                    </a>{" "}
                    to read the archive.
                </p>
            ) : (
                <ul class="posts__list">
                    {posts.map((post) => (
                        <li class="posts__item">
                            <time
                                class="posts__date"
                                datetime={post.publishedIso}
                            >
                                {formatDate(post.publishedIso)}
                            </time>
                            <a
                                class="posts__link"
                                href={post.url}
                                rel="noopener noreferrer"
                            >
                                {post.title}
                            </a>
                        </li>
                    ))}
                </ul>
            )
        }
    </section>

    <section class="now">
        <header class="section-header">
            <h2 class="section-header__title">Now</h2>
            <a class="section-header__cta" href="/now">See all ↗</a>
        </header>
        <NowFeed />
    </section>
</BaseLayout>

<style>
    /* ── Hero ── */
    .hero {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        margin-bottom: 2.5rem;
    }
    .hero__title {
        margin: 0;
        font-size: clamp(3rem, 8vw, 4.5rem);
        letter-spacing: -0.04em;
        line-height: 0.95;
        text-transform: lowercase;
    }
    .hero__bio {
        margin: 0;
        max-width: 62ch;
        color: var(--color-muted);
        font-size: 0.95rem;
        line-height: 1.8;
    }

    /* ── Social icons row ── */
    .social-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 3rem;
    }
    .social-row__label {
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--color-muted);
        white-space: nowrap;
    }
    .social-icons {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        list-style: none;
        margin: 0;
        padding: 0;
    }
    .social-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.1rem;
        height: 2.1rem;
        border-radius: var(--radius-sm);
        color: var(--color-muted);
        transition:
            color var(--transition-base),
            background var(--transition-base);
    }
    .social-icon:hover,
    .social-icon:focus-visible {
        color: var(--color-accent);
        background: var(--color-accent-dim);
        text-decoration: none;
    }
    .social-icon svg {
        width: 1.1rem;
        height: 1.1rem;
        flex-shrink: 0;
    }

    /* ── Section headers ── */
    .section-header {
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
    }
    .section-header__title {
        margin: 0;
        font-size: 0.82rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-accent);
    }
    .section-header__cta {
        margin-left: auto;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--color-muted);
        transition: color var(--transition-base);
    }
    .section-header__cta:hover {
        color: var(--color-accent);
        text-decoration: none;
    }

    /* ── Posts ── */
    .posts {
        display: flex;
        flex-direction: column;
        margin-bottom: 3.5rem;
    }
    .posts__list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 1.1rem;
    }
    .posts__item {
        display: grid;
        grid-template-columns: minmax(110px, 150px) 1fr;
        gap: 1.25rem;
        align-items: center;
        padding-bottom: 1.1rem;
        border-bottom: 1px solid var(--color-border);
    }
    .posts__item:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }
    .posts__date {
        font-size: 0.78rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--color-muted);
    }
    .posts__link {
        font-size: 0.95rem;
        color: var(--color-text);
        transition: color var(--transition-base);
    }
    .posts__link:hover,
    .posts__link:focus-visible {
        color: var(--color-accent);
        text-decoration: none;
    }

    /* ── Status ── */
    .status {
        margin: 0;
        font-size: 0.92rem;
        color: var(--color-muted);
    }
    .status--error {
        color: var(--color-error);
    }

    /* ── Now ── */
    .now {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* ── Responsive ── */
    @media (max-width: 720px) {
        .posts__item {
            grid-template-columns: 1fr;
            gap: 0.5rem;
            align-items: flex-start;
        }
        .social-row {
            flex-wrap: wrap;
            gap: 0.75rem;
        }
    }
</style>
