---
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { BearBlogPost } from "@/utils/rss";
import { fetchBearBlogFeed } from "@/utils/rss";

const POST_LIMIT = 3;

let posts: BearBlogPost[] = [];
let errorMessage: string | null = null;

try {
	posts = await fetchBearBlogFeed(POST_LIMIT);
} catch (error) {
	errorMessage =
		error instanceof Error ? error.message : "Unable to load recent posts right now.";
}

const formatDate = (isoDate: string) =>
	new Date(isoDate).toLocaleDateString("en-US", {
		year: "numeric",
		month: "short",
		day: "numeric",
	});
---

<BaseLayout description="Internet Archaeologist. Michelada Connoisseur. Founder of 0773H.">
	<header class="hero">
		<p class="hero__eyebrow">/home</p>
		<h1 class="hero__title">Gramajo</h1>
		<p class="hero__bio">
			Internet Archaeologist. Michelada Connoisseur. Founder of 0773H.
		</p>
	</header>

	<section class="section">
		<div class="section__heading">
			<h2>Recent posts</h2>
			<a class="section__cta" href="/blog">View all ↗</a>
		</div>

		{errorMessage ? (
			<p class="status status--error">{errorMessage}</p>
		) : posts.length === 0 ? (
			<p class="status">No posts found yet. Check back soon.</p>
		) : (
			<ul class="post-list">
				{posts.map((post) => (
					<li class="post-list__item">
						<a class="post-list__link" href={post.url} rel="noopener noreferrer">
							<span class="post-list__title">{post.title}</span>
							<time class="post-list__date" datetime={post.publishedIso}>
								{formatDate(post.publishedIso)}
							</time>
						</a>
					</li>
				))}
			</ul>
		)}
	</section>

	<section class="section">
		<div class="section__heading">
			<h2>Now</h2>
			<span class="section__hint">Live updates coming soon</span>
		</div>

		<ul class="now-list">
			<li class="now-list__item">Scouting the early NFT vaults for overlooked provenance.</li>
			<li class="now-list__item">Producing the next 0773H audio dispatch.</li>
			<li class="now-list__item">Mapping Bluesky communities ahead of a public toolkit.</li>
		</ul>
	</section>
</BaseLayout>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-bottom: 2.75rem;
	}

	.hero__eyebrow {
		margin: 0;
		font-size: 0.8rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.hero__title {
		margin: 0;
		font-size: clamp(2.5rem, 6vw, 3.4rem);
	}

	.hero__bio {
		margin: 0;
		max-width: 62ch;
		color: var(--color-muted);
		font-size: 1rem;
		line-height: 1.75;
	}

	.section {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		margin-bottom: 3rem;
	}

	.section:last-of-type {
		margin-bottom: 0;
	}

	.section__heading {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.75rem;
	}

	.section__heading h2 {
		margin: 0;
		font-size: 1.3rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.section__cta {
		margin-left: auto;
		font-size: 0.82rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-accent);
	}

	.section__hint {
		font-size: 0.8rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.status {
		margin: 0;
		font-size: 0.95rem;
		color: var(--color-muted);
	}

	.status--error {
		color: #f87171;
	}

	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1.15rem;
	}

	.post-list__item {
		border-bottom: 1px solid var(--color-border);
		padding-bottom: 1.15rem;
	}

	.post-list__item:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.post-list__link {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		width: 100%;
	}

	.post-list__title {
		font-size: 1rem;
		font-weight: 500;
		color: var(--color-text);
		transition: color var(--transition-base);
	}

	.post-list__date {
		flex-shrink: 0;
		font-size: 0.85rem;
		color: var(--color-muted);
		letter-spacing: 0.04em;
	}

	.post-list__link:hover .post-list__title,
	.post-list__link:focus-visible .post-list__title {
		color: var(--color-accent);
	}

	.now-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 1rem;
	}

	.now-list__item {
		margin: 0;
		padding: 1rem 1.2rem;
		border: 1px solid var(--color-border);
		border-radius: var(--radius-card);
		background: rgba(255, 255, 255, 0.02);
		color: var(--color-text);
		font-size: 0.95rem;
		line-height: 1.6;
	}

	@media (max-width: 640px) {
		.hero {
			gap: 0.85rem;
		}

		.hero__bio {
			font-size: 0.95rem;
		}

		.section__heading {
			flex-direction: column;
			align-items: flex-start;
		}
	}

	@media (max-width: 560px) {
		.post-list__link {
			flex-direction: column;
			align-items: flex-start;
		}

		.post-list__date {
			font-size: 0.8rem;
		}
	}
</style>
