---
import BaseLayout from "@/layouts/BaseLayout.astro";

const feeds = [
	{
		label: "Bear Blog RSS",
		url: "https://0xgramajo.xyz/feed/",
		description: "Primary writing feed — posts on crypto history, governance archaeology, and media experiments.",
	},
];

const people = [
	{ name: "Steve Dylan", url: "https://stevedylandev.bearblog.dev" },
	{ name: "Vrypan", url: "https://blog.vrypan.net" },
	{ name: "Vitalik", url: "https://vitalik.eth.limo" },
	{ name: "Dylan Steck", url: "https://dylansteck.com" },
];
---

<BaseLayout
	title="Feeds"
	description="Syndication endpoints and the independent voices I follow. Subscribe, mirror, or pipe these into your reader."
>
	<header class="feeds-header">
		<p class="feeds-eyebrow">/feeds</p>
		<h1 class="feeds-title">Signal sources</h1>
		<p class="feeds-description">
			Grab the Gramajo RSS feed or plug into the writers and researchers whose work shapes the archive. Everything here
			plays nicely with your reader, whether that’s Monocle, NetNewsWire, or a hand-rolled terminal client.
		</p>
	</header>

	<section class="feeds-section" aria-labelledby="feed-endpoints">
		<h2 id="feed-endpoints">Available feeds</h2>
		<ul class="feeds-list">
			{feeds.map((feed) => (
				<li class="feeds-item">
					<div class="feeds-item__meta">
						<a class="feeds-item__link" href={feed.url} rel="noopener noreferrer">
							{feed.label}
						</a>
						<span class="feeds-item__url">{feed.url}</span>
					</div>
					<p class="feeds-item__description">{feed.description}</p>
				</li>
			))}
		</ul>
	</section>

	<section class="feeds-section" aria-labelledby="followed-voices">
		<h2 id="followed-voices">People I follow</h2>
		<ul class="people-list">
			{people.map((person) => (
				<li class="people-item">
					<a class="people-link" href={person.url} rel="noopener noreferrer">
						<span class="people-name">{person.name}</span>
						<span class="people-url">{person.url}</span>
					</a>
				</li>
			))}
		</ul>
	</section>
</BaseLayout>

<style>
	.feeds-header {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-bottom: 2.75rem;
	}

	.feeds-eyebrow {
		margin: 0;
		font-size: 0.8rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.feeds-title {
		margin: 0;
		font-size: clamp(2.3rem, 5vw, 3rem);
	}

	.feeds-description {
		margin: 0;
		max-width: 64ch;
		color: var(--color-muted);
		line-height: 1.7;
		font-size: 0.96rem;
	}

	.feeds-section {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		margin-bottom: 2.75rem;
	}

	.feeds-section:last-of-type {
		margin-bottom: 0;
	}

	.feeds-section h2 {
		margin: 0;
		font-size: 1.25rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.feeds-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.feeds-item {
		border: 1px solid var(--color-border);
		border-radius: calc(var(--radius-card) / 1.2);
		padding: clamp(1.5rem, 4vw, 2rem);
		background: rgba(32, 32, 32, 0.85);
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
	}

	.feeds-item__meta {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.feeds-item__link {
		color: var(--color-accent);
		font-size: 1rem;
		font-weight: 600;
	}

	.feeds-item__url {
		font-size: 0.82rem;
		color: var(--color-muted);
		letter-spacing: 0.03em;
	}

	.feeds-item__description {
		margin: 0;
		color: var(--color-text);
		font-size: 0.95rem;
		line-height: 1.65;
	}

	.people-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 1rem;
	}

	.people-item {
		border: 1px solid var(--color-border);
		border-radius: calc(var(--radius-card) / 1.4);
		padding: clamp(1.2rem, 3vw, 1.6rem);
		background: rgba(30, 30, 30, 0.75);
		transition: border-color var(--transition-base);
	}

	.people-item:hover,
	.people-item:focus-within {
		border-color: var(--color-accent);
	}

	.people-link {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		color: var(--color-text);
	}

	.people-name {
		font-size: 1rem;
		font-weight: 500;
	}

	.people-url {
		font-size: 0.82rem;
		color: var(--color-muted);
		letter-spacing: 0.03em;
	}

	@media (max-width: 640px) {
		.feeds-header {
			gap: 0.75rem;
		}

		.feeds-description {
			font-size: 0.9rem;
		}

		.feeds-item {
			padding: 1.4rem;
		}

		.people-item {
			padding: 1.2rem;
		}
	}
</style>
