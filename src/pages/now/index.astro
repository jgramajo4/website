---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NowFeed from "@/components/now/NowFeed.astro";
---

<BaseLayout
	title="Now"
	description="Live updates on what Gramajo is researching, reading, and building."
>
	<header class="page-header">
		<a class="page-header__back" href="/now" hidden>← Back to Now</a>
		<h1 class="page-title">What I'm focused on now</h1>
		<p class="page-description">
			This page captures the current threads I'm tugging on. Expect it to shift often.
		</p>
	</header>

	<section id="now-detail" class="detail-wrapper" hidden>
		<article class="now-post__card" data-state="idle">
			<p class="now-post__status">Fetching that update… hang tight.</p>
		</article>
	</section>

	<section id="now-topics" class="now-topics">
		<h2>Currently exploring</h2>
		<ul>
			<li>Birding — logging sightings, gear, and patches</li>
			<li>Meshcore — off-grid mesh networking and LoRa experiments</li>
			<li>Chaumian ecash protocols — Cashu, Fedimint, and blind signatures</li>
			<li>Zcash — shielded transactions and the cypherpunk privacy stack</li>
			<li>RWAs — tokenizing collectibles and physical assets onchain</li>
		</ul>
	</section>

	<section id="now-feed" class="now-feed-wrapper">
		<header class="now-feed__header">
			<h2>Latest signals</h2>
			<p>
				Pulled from Bluesky, or my Telegram channel if Bluesky is unreachable.
			</p>
		</header>

		<NowFeed />
	</section>

	<script type="module">
		(async () => {
			const params = new URLSearchParams(window.location.search);
			const rkey = params.get("rkey");

			const detailSection = document.getElementById("now-detail");
			const topicsSection = document.getElementById("now-topics");
			const feedSection = document.getElementById("now-feed");
			const backLink = document.querySelector(".page-header__back");
			const titleEl = document.querySelector(".page-title");
			const descEl = document.querySelector(".page-description");

			const escapeHtml = (value) =>
				String(value)
					.replace(/&/g, "&amp;")
					.replace(/</g, "&lt;")
					.replace(/>/g, "&gt;");

			const formatText = (value) => escapeHtml(value).replace(/\n/g, "<br />");

			if (!rkey) {
				backLink?.setAttribute("hidden", "");
				detailSection?.setAttribute("hidden", "");
				topicsSection?.removeAttribute("hidden");
				feedSection?.removeAttribute("hidden");
				return;
			}

			backLink?.removeAttribute("hidden");
			detailSection?.removeAttribute("hidden");
			topicsSection?.setAttribute("hidden", "");
			feedSection?.setAttribute("hidden", "");

			if (titleEl) titleEl.textContent = "Now update";
			if (descEl) descEl.textContent = `Pulled live from Bluesky.`;

			const renderStatus = (message, variant = "info") => {
				if (!detailSection) return;
				const isError = variant === "error";
				detailSection.innerHTML = `
					<article class="now-post__card" data-state="${variant}">
						<p class="now-post__status${isError ? " now-post__status--error" : ""}">${escapeHtml(message)}</p>
					</article>`;
			};

			const renderPost = (htmlText, createdAtIso, createdAtLabel) => {
				if (!detailSection) return;
				detailSection.innerHTML = `
					<article class="now-post__card" data-state="success" aria-live="polite">
						<header class="now-post__header">
							<time class="now-post__timestamp" datetime="${escapeHtml(createdAtIso)}">${escapeHtml(createdAtLabel)}</time>
							<button type="button" class="now-post__copy" data-status="idle">Copy link</button>
						</header>
						<p class="now-post__text">${htmlText}</p>
					</article>`;

				const copyButton = detailSection.querySelector(".now-post__copy");
				if (!copyButton) return;

				const resetButton = () => {
					copyButton.dataset.status = "idle";
					copyButton.textContent = "Copy link";
				};

				copyButton.addEventListener("click", async () => {
					try {
						await navigator.clipboard.writeText(window.location.href);
						copyButton.dataset.status = "copied";
						copyButton.textContent = "Copied ✓";
					} catch {
						copyButton.dataset.status = "error";
						copyButton.textContent = "Copy failed";
					}
					setTimeout(resetButton, 2500);
				});
			};

			// Resolve handle → DID first, then fetch the specific record
			const formatter = new Intl.DateTimeFormat("en-US", {
				dateStyle: "medium",
				timeStyle: "short",
			});

			renderStatus("Fetching that update… hang tight.", "loading");

			try {
				const resolveResp = await fetch(
					"https://public.api.bsky.app/xrpc/com.atproto.identity.resolveHandle?handle=gramajo.xyz",
					{ headers: { Accept: "application/json" } }
				);
				if (!resolveResp.ok) throw new Error("Handle resolve failed");
				const { did } = await resolveResp.json();
				if (!did) throw new Error("No DID returned");

				const endpoint = new URL("https://public.api.bsky.app/xrpc/com.atproto.repo.getRecord");
				endpoint.searchParams.set("repo", did);
				endpoint.searchParams.set("collection", "app.bsky.feed.post");
				endpoint.searchParams.set("rkey", rkey);

				const response = await fetch(endpoint.toString(), { headers: { Accept: "application/json" } });
				if (!response.ok) throw new Error(`API responded with ${response.status}`);

				const data = await response.json();
				const record = data?.value ?? {};
				const text = typeof record.text === "string" ? record.text.trim() : "";
				const createdAt = typeof record.createdAt === "string" ? record.createdAt : "";

				if (!text || !createdAt) throw new Error("Post data was incomplete or malformed.");

				const date = new Date(createdAt);
				const createdAtLabel = isNaN(date.getTime()) ? createdAt : formatter.format(date);
				renderPost(formatText(text), createdAt, createdAtLabel);
			} catch (error) {
				console.error("[Now] failed to load post", error);
				renderStatus(error?.message ?? "Unable to reach the Bluesky API right now.", "error");
			}
		})();
	</script>
</BaseLayout>

<style>
	[hidden] { display: none !important; }

	.page-header {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-bottom: 2.75rem;
	}
	.page-header__back {
		font-size: 0.82rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-accent);
	}
	.page-title {
		margin: 0;
		font-size: clamp(2.1rem, 5vw, 2.8rem);
	}
	.page-description {
		margin: 0;
		max-width: 60ch;
		color: var(--color-muted);
		font-size: 0.95rem;
	}

	/* ── Single post detail ── */
	.detail-wrapper {
		display: flex;
		flex-direction: column;
		gap: 1.75rem;
	}
	.now-post__card {
		border: 1px solid var(--color-border);
		border-radius: calc(var(--radius-card) / 1.1);
		background: var(--color-surface-2);
		padding: clamp(1.5rem, 4vw, 2.25rem);
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		box-shadow: var(--shadow-lift);
	}
	.now-post__status { margin: 0; color: var(--color-muted); font-size: 0.95rem; }
	.now-post__status--error { color: var(--color-error); }
	.now-post__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.now-post__timestamp {
		color: var(--color-muted);
		font-size: 0.82rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}
	.now-post__copy {
		font-size: 0.75rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		background: transparent;
		border: 1px solid var(--color-border-2);
		color: var(--color-text-2);
		padding: 0.45rem 0.9rem;
		border-radius: var(--radius-sm);
		cursor: pointer;
		transition: border-color var(--transition-base), color var(--transition-base);
	}
	.now-post__copy:hover,
	.now-post__copy[data-status="copied"] { border-color: var(--color-accent); color: var(--color-accent); }
	.now-post__copy[data-status="error"] { border-color: var(--color-error); color: var(--color-error); }
	.now-post__text { margin: 0; color: var(--color-text); line-height: 1.7; font-size: 1rem; white-space: pre-wrap; }

	/* ── Currently exploring ── */
	.now-topics {
		border: 1px solid var(--color-border);
		border-radius: calc(var(--radius-card) / 1.2);
		background: var(--color-surface-2);
		padding: clamp(1.5rem, 4vw, 2rem);
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-bottom: 3rem;
	}
	.now-topics h2 {
		margin: 0;
		font-size: 0.82rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-accent);
	}
	.now-topics ul {
		margin: 0;
		padding-left: 1.5rem;
		display: grid;
		gap: 0.65rem;
	}
	.now-topics li { color: var(--color-text); line-height: 1.6; font-size: 0.95rem; }

	/* ── Feed section ── */
	.now-feed-wrapper {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}
	.now-feed__header { display: flex; flex-direction: column; gap: 0.5rem; }
	.now-feed__header h2 { margin: 0; font-size: 0.82rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-accent); }
	.now-feed__header p { margin: 0; max-width: 52ch; font-size: 0.88rem; color: var(--color-muted); }

	@media (max-width: 620px) {
		.now-post__header { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
		.now-post__copy { width: 100%; text-align: center; }
		.now-topics ul { padding-left: 1.25rem; }
	}
</style>
