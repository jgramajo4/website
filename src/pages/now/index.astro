---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NowFeed from "@/components/now/NowFeed.astro";
---

<BaseLayout
	title="Now"
	description="Live updates on what Gramajo is researching, reading, and building."
>
	<header class="page-header">
		<a class="page-header__back" href="/now" hidden>← Back to Now</a>
		<h1 class="page-title">What I'm focused on now</h1>
		<p class="page-description">
			This page captures the current threads I'm tugging on. Expect it to shift often.
		</p>
	</header>

	<section id="now-detail" class="detail-wrapper" hidden>
		<article class="now-post__card" data-state="idle">
			<p class="now-post__status">Fetching that update… hang tight.</p>
		</article>
	</section>

	<section id="now-topics" class="now-topics">
		<h2>Currently exploring</h2>
		<ul>
			<li>Reading: Placeholder book / paper title (I'll update this)</li>
			<li>Building: Placeholder project focus or experiment</li>
			<li>Listening: Placeholder podcast or mix</li>
			<li>Tracking: Placeholder governance proposal or token experiment</li>
		</ul>
	</section>

	<section id="now-feed" class="now-feed">
		<header class="now-feed__header">
			<h2>Latest signals</h2>
			<p>
				Pulled directly from my Bluesky feed. Each entry links to its
				permalink here.
			</p>
		</header>

		<NowFeed />
	</section>

	<script type="module">
		(async () => {
			const params = new URLSearchParams(window.location.search);
			const rkey = params.get("rkey");

			const detailSection = document.getElementById("now-detail");
			const topicsSection = document.getElementById("now-topics");
			const feedSection = document.getElementById("now-feed");
			const backLink = document.querySelector(".page-header__back");
			const titleEl = document.querySelector(".page-title");
			const descEl = document.querySelector(".page-description");

			const escapeHtml = (value) =>
				String(value)
					.replace(/&/g, "&amp;")
					.replace(/</g, "&lt;")
					.replace(/>/g, "&gt;");

			const formatText = (value) => escapeHtml(value).replace(/\n/g, "<br />");

			if (!rkey) {
				backLink?.setAttribute("hidden", "");
				detailSection?.setAttribute("hidden", "");
				topicsSection?.removeAttribute("hidden");
				feedSection?.removeAttribute("hidden");
				return;
			}

			backLink?.removeAttribute("hidden");
			detailSection?.removeAttribute("hidden");
			topicsSection?.setAttribute("hidden", "");
			feedSection?.setAttribute("hidden", "");

			if (titleEl) {
				titleEl.textContent = "Now update";
			}
			if (descEl) {
				descEl.textContent = `Pulled live from Bluesky with rkey ${rkey}.`;
			}

			const renderStatus = (message, variant = "info") => {
				if (!detailSection) return;
				const isError = variant === "error";
				const content = escapeHtml(message);
				detailSection.innerHTML = `
					<article class="now-post__card" data-state="${variant}">
						<p class="now-post__status${isError ? " now-post__status--error" : ""}">${content}</p>
					</article>
				`;
			};

			const renderPost = (htmlText, createdAtIso, createdAtLabel) => {
				if (!detailSection) return;
				detailSection.innerHTML = `
					<article class="now-post__card" data-state="success" aria-live="polite">
						<header class="now-post__header">
							<time class="now-post__timestamp" datetime="${escapeHtml(createdAtIso)}">${escapeHtml(createdAtLabel)}</time>
							<button type="button" class="now-post__copy" data-status="idle">Copy link</button>
						</header>
						<p class="now-post__text">${htmlText}</p>
					</article>
				`;

				const copyButton = detailSection.querySelector(".now-post__copy");
				if (!copyButton) return;

				const resetButton = () => {
					copyButton.dataset.status = "idle";
					copyButton.textContent = "Copy link";
				};

				copyButton.addEventListener("click", async () => {
					try {
						const targetUrl = window.location.href;
						if (navigator.clipboard?.writeText) {
							await navigator.clipboard.writeText(targetUrl);
						} else {
							const textarea = document.createElement("textarea");
							textarea.value = targetUrl;
							textarea.style.position = "fixed";
							textarea.style.top = "-9999px";
							document.body.appendChild(textarea);
							textarea.focus();
							textarea.select();
							document.execCommand("copy");
							document.body.removeChild(textarea);
						}
						copyButton.dataset.status = "copied";
						copyButton.textContent = "Copied ✓";
					} catch (error) {
						console.error("[Now] copy failed", error);
						copyButton.dataset.status = "error";
						copyButton.textContent = "Copy failed";
					} finally {
						setTimeout(resetButton, 2500);
					}
				});
			};

			const endpoint = new URL("https://public.api.bsky.app/xrpc/com.atproto.repo.getRecord");
			endpoint.searchParams.set("repo", "gramajo.xyz");
			endpoint.searchParams.set("collection", "app.bsky.feed.post");
			endpoint.searchParams.set("rkey", rkey);

			const formatter = new Intl.DateTimeFormat("en-US", {
				dateStyle: "medium",
				timeStyle: "short",
			});

			renderStatus("Fetching that update… hang tight.", "loading");

			try {
				const response = await fetch(endpoint.toString(), {
					headers: { Accept: "application/json" },
				});

				if (!response.ok) {
					throw new Error(`API responded with ${response.status}`);
				}

				const payload = await response.json();
				const record = payload?.value ?? {};
				const text = typeof record.text === "string" ? record.text.trim() : "";
				const createdAt = typeof record.createdAt === "string" ? record.createdAt : "";

				if (!text || !createdAt) {
					throw new Error("Post data was incomplete or malformed.");
				}

				const date = new Date(createdAt);
				const createdAtLabel = Number.isNaN(date.getTime()) ? createdAt : formatter.format(date);

				renderPost(formatText(text), createdAt, createdAtLabel);
			} catch (error) {
				console.error("[Now] failed to load post", error);
				const message = error instanceof Error ? error.message : "Unable to reach the Bluesky public API right now.";
				renderStatus(message, "error");
			}
		})();
	</script>
</BaseLayout>

<style>
	[hidden] {
		display: none !important;
	}

	.page-header {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-bottom: 2.75rem;
	}

	.page-header__back {
		font-size: 0.82rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.page-title {
		margin: 0;
		font-size: clamp(2.1rem, 5vw, 2.8rem);
	}

	.page-description {
		margin: 0;
		max-width: 60ch;
		color: var(--color-muted);
		font-size: 0.95rem;
	}

	.detail-wrapper {
		display: flex;
		flex-direction: column;
		gap: 1.75rem;
	}

	.now-post__card {
		border: 1px solid var(--color-border);
		border-radius: calc(var(--radius-card) / 1.1);
		background: rgba(42, 42, 42, 0.75);
		padding: clamp(1.5rem, 4vw, 2.25rem);
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		box-shadow: 0 24px 50px rgba(0, 0, 0, 0.35);
	}

	.now-post__status {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.95rem;
	}

	.now-post__status--error {
		color: #f87171;
	}

	.now-post__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.now-post__timestamp {
		color: var(--color-muted);
		font-size: 0.85rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.now-post__copy {
		font-family: var(--font-mono);
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		background: transparent;
		border: 1px solid var(--color-border);
		color: var(--color-text);
		padding: 0.55rem 1rem;
		border-radius: calc(var(--radius-card) / 2);
		cursor: pointer;
		transition: border-color var(--transition-base), color var(--transition-base);
	}

	.now-post__copy:hover,
	.now-post__copy:focus-visible,
	.now-post__copy[data-status="copied"] {
		border-color: var(--color-accent);
		color: var(--color-accent);
	}

	.now-post__copy[data-status="error"] {
		border-color: #f87171;
		color: #f87171;
	}

	.now-post__text {
		margin: 0;
		color: var(--color-text);
		line-height: 1.7;
		font-size: 1.02rem;
		white-space: pre-wrap;
	}

	.now-topics {
		border: 1px solid var(--color-border);
		border-radius: calc(var(--radius-card) / 1.2);
		background: rgba(26, 26, 26, 0.55);
		padding: clamp(1.5rem, 4vw, 2rem);
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-bottom: 3rem;
	}

	.now-topics h2 {
		margin: 0;
		font-size: 1.15rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.now-topics ul {
		margin: 0;
		padding-left: 1.5rem;
		display: grid;
		gap: 0.75rem;
	}

	.now-topics li {
		color: var(--color-text);
		line-height: 1.6;
	}

	.now-feed {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.now-feed__header {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.now-feed__header h2 {
		margin: 0;
		font-size: 1.4rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	.now-feed__header p {
		margin: 0;
		max-width: 48ch;
		font-size: 0.9rem;
		color: var(--color-muted);
	}

	@media (max-width: 620px) {
		.now-post__header {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.75rem;
		}

		.now-post__copy {
			width: 100%;
			text-align: center;
		}

		.now-topics ul {
			padding-left: 1.25rem;
		}

		.page-header__back {
			font-size: 0.78rem;
		}
	}
</style>
