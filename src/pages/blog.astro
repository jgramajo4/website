---
import BaseLayout from "@/layouts/BaseLayout.astro";
import type { BearBlogPost } from "@/utils/rss";
import { BearBlogFeedError, fetchBearBlogFeed } from "@/utils/rss";

const MAX_POSTS = 50;
const BEAR_BLOG_URL = "https://0xgramajo.xyz/blog/";

let posts: BearBlogPost[] = [];
let errorMessage: string | null = null;
let fallbackUrl = BEAR_BLOG_URL;

try {
	posts = await fetchBearBlogFeed(MAX_POSTS);
} catch (error) {
	console.error("[blog] Failed to load Bear Blog feed.", error);
	if (error instanceof BearBlogFeedError) {
		errorMessage = "Unable to load the Bear Blog feed right now.";
		fallbackUrl = error.fallbackUrl;
	} else if (error instanceof Error) {
		errorMessage = error.message;
	} else {
		errorMessage = "Unable to load the latest posts right now.";
	}
}

const formatDate = (isoDate: string) =>
	new Date(isoDate).toLocaleDateString("en-US", {
		year: "numeric",
		month: "short",
		day: "numeric",
	});
---

<BaseLayout
	title="Blog"
	description="Recent writing from Gramajo published on Bear Blog."
>
	<header class="page-header">
		<h1 class="page-title">Recent writing</h1>
		<p class="page-description">
			Links point to the original posts on Bear Blog. Entries are kept lean on
			purpose: title and timestamp, nothing more.
		</p>
	</header>

	{errorMessage ? (
		<p class="status status--error">
			{errorMessage}{" "}
			<a href={fallbackUrl} rel="noopener noreferrer">Visit Bear Blog ↗</a>
		</p>
	) : posts.length === 0 ? (
		<p class="status">
			No posts available right now. Visit{" "}
			<a href={BEAR_BLOG_URL} rel="noopener noreferrer">Bear Blog ↗</a> to read the archive.
		</p>
	) : (
		<ul class="post-list">
			{posts.map((post) => (
				<li class="post-list__item">
					<a class="post-list__link" href={post.url} rel="noopener noreferrer">
						<span class="post-list__title">{post.title}</span>
						<time class="post-list__date" datetime={post.publishedIso}>
							{formatDate(post.publishedIso)}
						</time>
					</a>
				</li>
			))}
		</ul>
	)}
</BaseLayout>

<style>
	.page-header {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-bottom: 2.5rem;
	}

	.page-title {
		margin: 0;
		font-size: clamp(2rem, 4vw, 2.5rem);
	}

	.page-description {
		margin: 0;
		max-width: 56ch;
		color: var(--color-muted);
	}

	.status {
		margin: 0;
		font-size: 0.95rem;
		color: var(--color-muted);
	}

	.status--error {
		color: #f87171;
	}

	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.post-list__item {
		border-bottom: 1px solid var(--color-border);
		padding-bottom: 1rem;
	}

	.post-list__item:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.post-list__link {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		width: 100%;
	}

	.post-list__title {
		font-size: 1rem;
		font-weight: 500;
		color: var(--color-text);
		transition: color var(--transition-base);
	}

	.post-list__date {
		flex-shrink: 0;
		font-size: 0.85rem;
		color: var(--color-muted);
		letter-spacing: 0.04em;
	}

	.post-list__link:hover .post-list__title,
	.post-list__link:focus-visible .post-list__title {
		color: var(--color-accent);
	}

	@media (max-width: 560px) {
		.post-list__link {
			flex-direction: column;
			align-items: flex-start;
		}

		.post-list__date {
			font-size: 0.8rem;
		}
	}
</style>
