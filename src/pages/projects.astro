---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectCard from "@/components/projects/ProjectCard.astro";
import { getCollection } from "astro:content";

const STATUS_ORDER = ["active", "building", "archived"] as const;

const projects = (await getCollection("projects"))
	.map(({ data }) => data)
	.sort((a, b) => STATUS_ORDER.indexOf(a.status) - STATUS_ORDER.indexOf(b.status));
---

<BaseLayout
	title="Projects"
	description="A running index of research labs, media experiments, and decentralized investigations stewarded by Gramajo."
>
	<header class="projects-header">
		<p class="projects-header__eyebrow">/projects</p>
		<h1 class="projects-header__title">Experiments &amp; labs</h1>
		<p class="projects-header__description">
			Active builds come first, followed by work in-progress and retired experiments. Each entry links out to its live
			home on the web or onchain.
		</p>
	</header>

	<section class="projects-grid" aria-label="Projects list">
		{projects.length === 0 ? (
			<p class="projects-empty">No projects cataloged yet. Check back soon.</p>
		) : (
			projects.map((project) => <ProjectCard project={project} />)
		)}
	</section>
</BaseLayout>

<style>
	.projects-header {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-bottom: 2.75rem;
	}

	.projects-header__eyebrow {
		margin: 0;
		font-size: 0.8rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.projects-header__title {
		margin: 0;
		font-size: clamp(2.3rem, 5vw, 3rem);
	}

	.projects-header__description {
		margin: 0;
		max-width: 62ch;
		color: var(--color-muted);
		font-size: 0.96rem;
		line-height: 1.7;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1.75rem;
	}

	.projects-empty {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.95rem;
	}

	@media (max-width: 640px) {
		.projects-header {
			gap: 0.75rem;
		}

		.projects-header__description {
			font-size: 0.9rem;
		}
	}
</style>
